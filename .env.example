# ============================================
# Transcription & Segmentation App - Environment
# ============================================

# Application
APP_NAME=Transcription & Segmentation App
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api/v1

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=transcription_db
DB_USER=postgres
DB_PASSWORD=postgres

# Redis (Celery broker + result backend)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# MinIO (Object Storage)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=uploads

# Whisper Transcription (CPU-optimized)
# Models: tiny, base, small, medium, large (base recommended for CPU)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# File Upload Settings
MAX_UPLOAD_SIZE=104857600
UPLOAD_DIR=/tmp/uploads
